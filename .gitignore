# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.key
*.crt
*.p12
*.pfx

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# env files
.env
.env.*
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# supabase
/supabase/.branches
/supabase/.temp
/supabase/migrations/*.down.sql
supabase/seed.sql

# secrets & credentials
*.secret
secrets/
credentials/
serviceAccountKey.json
*service_account*.json
.htpasswd

# OS
Thumbs.db
ehthumbs.db
Desktop.ini
