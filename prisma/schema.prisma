generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model audit_logs {
  id          String    @id @db.Char(36)
  user_id     String?   @db.Char(36)
  action      String    @db.VarChar(100)
  entity_type String?   @db.VarChar(50)
  entity_id   String?   @db.Char(36)
  metadata    Json?
  created_at  DateTime? @default(now()) @db.Timestamp(0)
}

model bookmark_collections {
  id             String           @id @db.Char(36)
  user_id        String           @db.Char(36)
  name           String           @db.VarChar(100)
  created_at     DateTime?        @default(now()) @db.Timestamp(0)
  updated_at     DateTime?        @default(now()) @db.Timestamp(0)
  users          users            @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_bc_user")
  bookmark_items bookmark_items[]

  @@index([user_id], map: "fk_bc_user")
}

model bookmark_items {
  collection_id        String               @db.Char(36)
  testimony_id         String               @db.Char(36)
  created_at           DateTime?            @default(now()) @db.Timestamp(0)
  bookmark_collections bookmark_collections @relation(fields: [collection_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_bi_collection")
  testimonies          testimonies          @relation(fields: [testimony_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_bi_testimony")

  @@id([collection_id, testimony_id])
  @@index([testimony_id], map: "fk_bi_testimony")
}

model categories {
  id               String             @id @db.Char(36)
  name             String             @unique(map: "name") @db.VarChar(100)
  slug             String             @unique(map: "slug") @db.VarChar(100)
  description      String?            @db.Text
  created_at       DateTime?          @default(now()) @db.Timestamp(0)
  category_follows category_follows[]
  testimonies      testimonies[]
}

model category_follows {
  user_id     String     @db.Char(36)
  category_id String     @db.Char(36)
  created_at  DateTime?  @default(now()) @db.Timestamp(0)
  categories  categories @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_cf_category")
  users       users      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_cf_user")

  @@id([user_id, category_id])
  @@index([category_id], map: "idx_cf_category")
}

model comments {
  id           String      @id @db.Char(36)
  testimony_id String      @db.Char(36)
  user_id      String      @db.Char(36)
  body         String      @db.Text
  created_at   DateTime?   @default(now()) @db.Timestamp(0)
  updated_at   DateTime?   @default(now()) @db.Timestamp(0)
  deleted_at   DateTime?   @db.Timestamp(0)
  testimonies  testimonies @relation(fields: [testimony_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_comment_testimony")
  users        users       @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_comment_user")

  @@index([created_at], map: "idx_comment_created")
  @@index([testimony_id], map: "idx_comment_testimony")
  @@index([user_id], map: "idx_comment_user")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model follows {
  follower_id                       String    @db.Char(36)
  following_id                      String    @db.Char(36)
  created_at                        DateTime? @default(now()) @db.Timestamp(0)
  users_follows_follower_idTousers  users     @relation("follows_follower_idTousers", fields: [follower_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_follower")
  users_follows_following_idTousers users     @relation("follows_following_idTousers", fields: [following_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_following")

  @@id([follower_id, following_id])
  @@index([following_id], map: "idx_following")
}

model notifications {
  id                                      String    @id @db.Char(36)
  recipient_id                            String    @db.Char(36)
  actor_id                                String?   @db.Char(36)
  type                                    String    @db.VarChar(50)
  entity_type                             String?   @db.VarChar(50)
  entity_id                               String?   @db.Char(36)
  is_read                                 Boolean   @default(false)
  created_at                              DateTime? @default(now()) @db.Timestamp(0)
  users_notifications_actor_idTousers     users?    @relation("notifications_actor_idTousers", fields: [actor_id], references: [id], onUpdate: NoAction, map: "fk_notifications_actor")
  users_notifications_recipient_idTousers users     @relation("notifications_recipient_idTousers", fields: [recipient_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_notifications_recipient")

  @@index([actor_id], map: "fk_notifications_actor")
  @@index([recipient_id, is_read], map: "idx_notifications_recipient")
}

model profiles {
  id                     String    @id @db.Char(36)
  user_id                String    @unique(map: "user_id") @db.Char(36)
  display_id             String    @unique(map: "display_id") @db.VarChar(50)
  display_name           String?   @db.VarChar(100)
  bio                    String?   @db.Text
  avatar_url             String?   @db.VarChar(500)
  hide_identity_globally Boolean   @default(false)
  created_at             DateTime? @default(now()) @db.Timestamp(0)
  updated_at             DateTime? @default(now()) @db.Timestamp(0)
  users                  users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_profiles_user")
}

model rate_limits {
  id           String    @id @db.Char(36)
  ip_hash      String    @db.VarChar(255)
  action       String    @db.VarChar(100)
  count        Int       @default(1)
  window_start DateTime? @default(now()) @db.Timestamp(0)
  expires_at   DateTime  @db.Timestamp(0)

  @@index([ip_hash, action, expires_at], map: "idx_rate_limits_lookup")
}

model reactions {
  id           String      @id @db.Char(36)
  testimony_id String      @db.Char(36)
  user_id      String      @db.Char(36)
  type         String      @db.VarChar(50)
  created_at   DateTime?   @default(now()) @db.Timestamp(0)
  testimonies  testimonies @relation(fields: [testimony_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_reaction_testimony")
  users        users       @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_reaction_user")

  @@unique([testimony_id, user_id, type], map: "uq_reaction")
  @@index([testimony_id], map: "idx_reaction_testimony")
  @@index([type], map: "idx_reaction_type")
  @@index([user_id], map: "idx_reaction_user")
}

model reports {
  id           String         @id @db.Char(36)
  testimony_id String         @db.Char(36)
  user_id      String?        @db.Char(36)
  reason       String         @db.VarChar(100)
  description  String?        @db.Text
  status       reports_status @default(pending)
  created_at   DateTime?      @default(now()) @db.Timestamp(0)
  resolved_at  DateTime?      @db.Timestamp(0)
  testimonies  testimonies    @relation(fields: [testimony_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_reports_testimony")
  users        users?         @relation(fields: [user_id], references: [id], onUpdate: NoAction, map: "fk_reports_user")

  @@index([user_id], map: "fk_reports_user")
  @@index([status], map: "idx_reports_status")
  @@index([testimony_id], map: "idx_reports_testimony")
}

model shares {
  id           String          @id @db.Char(36)
  testimony_id String          @db.Char(36)
  user_id      String?         @db.Char(36)
  platform     shares_platform
  created_at   DateTime?       @default(now()) @db.Timestamp(0)
  testimonies  testimonies     @relation(fields: [testimony_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_shares_testimony")

  @@index([testimony_id, platform], map: "idx_shares_testimony")
}

model tags {
  id             String           @id @db.Char(36)
  name           String           @unique(map: "name") @db.VarChar(100)
  slug           String           @unique(map: "slug") @db.VarChar(100)
  created_at     DateTime?        @default(now()) @db.Timestamp(0)
  testimony_tags testimony_tags[]
}

model testimonies {
  id                 String              @id @db.Char(36)
  user_id            String?             @db.Char(36)
  category_id        String?             @db.Char(36)
  title              String?             @db.VarChar(255)
  excerpt            String?             @db.Text
  body               String              @db.Text
  status             testimonies_status  @default(draft)
  is_identity_hidden Boolean             @default(false)
  consented          Boolean             @default(false)
  created_at         DateTime?           @default(now()) @db.Timestamp(0)
  published_at       DateTime?           @db.Timestamp(0)
  deleted_at         DateTime?           @db.Timestamp(0)
  bookmark_items     bookmark_items[]
  comments           comments[]
  reactions          reactions[]
  reports            reports[]
  shares             shares[]
  categories         categories?         @relation(fields: [category_id], references: [id], onUpdate: NoAction, map: "fk_testimonies_category")
  users              users?              @relation(fields: [user_id], references: [id], onUpdate: NoAction, map: "fk_testimonies_user")
  testimony_exports  testimony_exports[]
  testimony_media    testimony_media[]
  testimony_tags     testimony_tags[]
  testimony_views    testimony_views[]

  @@index([category_id], map: "idx_testimonies_category")
  @@index([created_at], map: "idx_testimonies_created")
  @@index([status], map: "idx_testimonies_status")
  @@index([user_id], map: "idx_testimonies_user")
}

model testimony_exports {
  id           String                        @id @db.Char(36)
  testimony_id String                        @db.Char(36)
  user_id      String?                       @db.Char(36)
  export_type  testimony_exports_export_type
  created_at   DateTime?                     @default(now()) @db.Timestamp(0)
  testimonies  testimonies                   @relation(fields: [testimony_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_exports_testimony")

  @@index([testimony_id, export_type], map: "idx_exports_testimony")
}

model testimony_media {
  id               String               @id @db.Char(36)
  testimony_id     String               @db.Char(36)
  type             testimony_media_type
  storage_key      String               @db.VarChar(255)
  url              String               @db.VarChar(512)
  mime_type        String               @db.VarChar(100)
  file_size        Int
  duration_seconds Int?
  created_at       DateTime?            @default(now()) @db.Timestamp(0)
  testimonies      testimonies          @relation(fields: [testimony_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_media_testimony")

  @@index([testimony_id], map: "fk_media_testimony")
}

model testimony_tags {
  testimony_id String      @db.Char(36)
  tag_id       String      @db.Char(36)
  created_at   DateTime?   @default(now()) @db.Timestamp(0)
  tags         tags        @relation(fields: [tag_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_tt_tag")
  testimonies  testimonies @relation(fields: [testimony_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_tt_testimony")

  @@id([testimony_id, tag_id])
  @@index([tag_id], map: "fk_tt_tag")
}

model testimony_views {
  id           String      @id @db.Char(36)
  testimony_id String      @db.Char(36)
  user_id      String?     @db.Char(36)
  ip_hash      String?     @db.VarChar(255)
  source       String?     @db.VarChar(100)
  created_at   DateTime?   @default(now()) @db.Timestamp(0)
  testimonies  testimonies @relation(fields: [testimony_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_views_testimony")

  @@index([testimony_id, created_at], map: "idx_views_testimony")
}

model users {
  id                                              String                 @id @db.Char(36)
  email                                           String                 @unique(map: "email") @db.VarChar(255)
  password_hash                                   String?                @db.VarChar(255)
  auth_provider                                   users_auth_provider    @default(email)
  email_verified_at                               DateTime?              @db.Timestamp(0)
  created_at                                      DateTime?              @default(now()) @db.Timestamp(0)
  updated_at                                      DateTime?              @default(now()) @db.Timestamp(0)
  deleted_at                                      DateTime?              @db.Timestamp(0)
  bookmark_collections                            bookmark_collections[]
  category_follows                                category_follows[]
  comments                                        comments[]
  follows_follows_follower_idTousers              follows[]              @relation("follows_follower_idTousers")
  follows_follows_following_idTousers             follows[]              @relation("follows_following_idTousers")
  notifications_notifications_actor_idTousers     notifications[]        @relation("notifications_actor_idTousers")
  notifications_notifications_recipient_idTousers notifications[]        @relation("notifications_recipient_idTousers")
  profiles                                        profiles?
  reactions                                       reactions[]
  reports                                         reports[]
  testimonies                                     testimonies[]
}

model waitlist {
  id         String    @id @db.Char(36)
  email      String    @unique(map: "email") @db.VarChar(255)
  source     String?   @db.VarChar(100)
  ip_hash    String?   @db.VarChar(255)
  created_at DateTime? @default(now()) @db.Timestamp(0)
}

enum testimony_media_type {
  image
  video
  audio
}

enum shares_platform {
  whatsapp
  x
  facebook
  linkedin
  telegram
  copy_link
  other
}

enum testimony_exports_export_type {
  image
  pdf
}

enum users_auth_provider {
  email
  google
}

enum reports_status {
  pending
  reviewed
  resolved
}

enum testimonies_status {
  draft
  published
  removed
}
